{
  "name": "spck-networking",
  "version": "1.0.0",
  "description": "Unified network server for Spck Editor - provides remote filesystem, git, and terminal access",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "spck-networking": "./bin/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "spck",
    "editor",
    "remote",
    "filesystem",
    "git",
    "terminal"
  ],
  "author": "Spck Editor",
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/headless": "^5.5.0",
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "fossil-delta": "^1.0.2",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "node-pty": "^1.0.0",
    "open": "^8.4.2",
    "qrcode-terminal": "^0.12.0",
    "socket.io-client": "^4.7.0",
    "write-file-atomic": "^7.0.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.11",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/socket.io-client": "^3.0.0",
    "@types/write-file-atomic": "^4.0.3",
    "@types/ws": "^8.5.10",
    "@types/yargs": "^17.0.32",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
